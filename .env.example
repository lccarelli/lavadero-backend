# Server
PORT=3000
NODE_ENV=development

# Database
# Dentro de docker-compose: DB_HOST=mysql (nombre del servicio).
# Para correr el backend fuera de Docker (ej: tests locales): DB_HOST=localhost.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=lavadero_db
DB_USER=root
DB_PASSWORD=

# Sessions
SESSION_SECRET=cambiar-esto-en-produccion

# Frontend URL (para CORS) — nginx sirve el frontend en 8080
FRONTEND_URL=http://localhost:8080

# Uploads
UPLOAD_MAX_SIZE_MB=2

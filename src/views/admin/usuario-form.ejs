<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head', { title: 'Nuevo administrador' }) %>
</head>
<body class="admin">
  <%- include('../partials/admin-header', { usuario }) %>

  <main class="admin-main">
    <h1 class="admin-main__title">Nuevo administrador</h1>
    <p class="admin-main__subtitle">Creá un usuario con acceso al backoffice.</p>

    <div class="admin-form">
      <div id="form-errores"></div>

      <form id="usuario-form">
        <div class="field">
          <label class="field__label" for="nombre">Nombre</label>
          <div class="field__control">
            <span class="field__icon material-symbols-outlined">person</span>
            <input class="field__input" type="text" id="nombre" name="nombre" placeholder="Nombre del admin" required />
          </div>
        </div>
        <div class="field">
          <label class="field__label" for="email">Email</label>
          <div class="field__control">
            <span class="field__icon material-symbols-outlined">mail</span>
            <input class="field__input" type="email" id="email" name="email" placeholder="admin@lavadero.com" required />
          </div>
        </div>
        <div class="field">
          <label class="field__label" for="password">Contraseña</label>
          <div class="field__control">
            <span class="field__icon material-symbols-outlined">lock</span>
            <input class="field__input" type="password" id="password" name="password" placeholder="Mínimo 6 caracteres" required />
          </div>
        </div>

        <div class="admin-form__actions">
          <button type="submit" class="btn-primary">
            <span class="material-symbols-outlined">person_add</span>
            Crear administrador
          </button>
          <a class="admin-form__cancel" href="/admin/dashboard">Cancelar</a>
        </div>
      </form>
    </div>
  </main>

  <script src="/public/js/admin-usuario-form.js"></script>
</body>
</html>
